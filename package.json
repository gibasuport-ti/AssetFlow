    "jsonwebtoken": "^9.0.3",
    "motion": "^12.38.0"
  },
  "devDependencies": {
    "@azure/msal-browser": "^5.4.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
